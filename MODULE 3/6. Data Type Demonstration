class DataTypesDemo {
    public static void main(String[] args) {

        int a = 10;
        float b = 12.5f;
        double c = 123.456;
        char d = 'A';
        boolean e = true;

        System.out.println("Int = " + a);
        System.out.println("Float = " + b);
        System.out.println("Double = " + c);
        System.out.println("Char = " + d);
        System.out.println("Boolean = " + e);
    }
}
