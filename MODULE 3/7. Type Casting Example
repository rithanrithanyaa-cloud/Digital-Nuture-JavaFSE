class TypeCasting {
    public static void main(String[] args) {

        double d = 12.78;

        int i = (int)d;

        System.out.println("Double Value = " + d);
        System.out.println("After Casting to Int = " + i);

        int x = 50;

        double y = (double)x;

        System.out.println("Integer Value = " + x);
        System.out.println("After Casting to Double = " + y);
    }
}
