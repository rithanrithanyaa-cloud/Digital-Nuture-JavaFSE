class MyThread extends Thread {

    public void run() {

        for(int i=1;i<=5;i++) {

            System.out.println(
                "Thread Running : " + i
            );

            try {
                Thread.sleep(1000);
            }
            catch(Exception e) {}
        }
    }
}

class ThreadDemo {

    public static void main(String[] args) {

        MyThread t = new MyThread();

        t.start();
    }
}
