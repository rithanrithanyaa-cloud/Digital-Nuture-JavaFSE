import java.lang.reflect.*;

class Student {

    private int id;

    public void display() {

        System.out.println("Student");
    }
}

class ReflectionDemo {

    public static void main(String[] args)
        throws Exception {

        Class<?> cls = Student.class;

        System.out.println(
            "Class Name : "
            + cls.getName()
        );

        Method[] methods =
            cls.getDeclaredMethods();

        for(Method m : methods) {

            System.out.println(
                m.getName()
            );
        }
    }
}
