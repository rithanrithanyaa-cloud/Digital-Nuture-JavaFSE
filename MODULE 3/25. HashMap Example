import java.util.HashMap;

class HashMapDemo {

    public static void main(String[] args) {

        HashMap<Integer,String> students =
            new HashMap<>();

        students.put(101,"Rithanyaa");
        students.put(102,"Priya");
        students.put(103,"Kavin");

        System.out.println(students);

        System.out.println(
            students.get(101)
        );
    }
}
