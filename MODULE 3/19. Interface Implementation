interface Shape {

    double area();
}

class Circle implements Shape {

    double radius;

    Circle(double radius) {
        this.radius = radius;
    }

    public double area() {
        return 3.14 * radius * radius;
    }
}

class Main {

    public static void main(String[] args) {

        Circle c = new Circle(5);

        System.out.println("Area = " + c.area());
    }
}
